# tesseract.js: Node uses only the *.js + *.wasm pairs of the LSTM cores
# (OEM default). Legacy (non-lstm) cores and the single-file browser bundles
# (*.wasm.js) are dead weight in a VS Code extension.
node_modules/tesseract.js-core/tesseract-core.js
node_modules/tesseract.js-core/tesseract-core.wasm
node_modules/tesseract.js-core/tesseract-core-simd.js
node_modules/tesseract.js-core/tesseract-core-simd.wasm
node_modules/tesseract.js-core/tesseract-core-relaxedsimd.js
node_modules/tesseract.js-core/tesseract-core-relaxedsimd.wasm
node_modules/tesseract.js-core/*.wasm.js
node_modules/tesseract.js/dist/**
node_modules/zlibjs/bin/**
node_modules/zlibjs/src/**
node_modules/zlibjs/test/**
node_modules/**/*.md
node_modules/**/LICENSE*
node_modules/**/*.d.ts
